<div class="card">
  <div class="card-header"><h3>Riwayat Rekam Medis (<%= records.length %>)</h3></div>

  <% if (records.length === 0) { %>
    <div class="empty-state">
      <div class="empty-state-icon">&#128203;</div>
      <p>Anda belum memiliki rekam medis. Rekam medis akan tercatat setelah dokter mengisi hasil konsultasi.</p>
    </div>
  <% } else { %>
    <% records.forEach(r => { %>
      <div class="card" style="margin-bottom: 16px; border-left: 4px solid var(--color-primary-light);">
        <div style="display:flex; justify-content: space-between; align-items: flex-start;">
          <div>
            <h4 style="font-size: 1rem; margin-bottom: 4px;"><%= r.diagnosis %></h4>
            <p style="font-size: 0.82rem; color: var(--color-text-muted); margin: 0;">
              Dr. <%= r.doctor.user.username %> &middot; <%= new Date(r.date).toLocaleDateString('id-ID', { dateStyle: 'long' }) %>
            </p>
          </div>
          <a href="/api/export/health-record/<%= r.id %>/pdf" class="btn btn-outline btn-sm" target="_blank">Unduh PDF</a>
        </div>

        <% if (r.notes) { %>
          <p style="font-size: 0.88rem; margin-top: 12px; color: var(--color-text);"><%= r.notes %></p>
        <% } %>

        <% if (r.prescriptions.length > 0) { %>
          <div style="margin-top: 14px; padding-top: 14px; border-top: 1px solid var(--color-border);">
            <strong style="font-size: 0.85rem;">Resep Obat:</strong>
            <ul style="margin: 8px 0 0; padding-left: 20px; font-size: 0.85rem;">
              <% r.prescriptions.forEach(p => { %>
                <li><%= p.namaObat %> — <%= p.dosis %>, <%= p.durasi %><% if (p.catatan) { %> (<%= p.catatan %>)<% } %></li>
              <% }) %>
            </ul>
          </div>
        <% } %>
      </div>
    <% }) %>
  <% } %>
</div>
