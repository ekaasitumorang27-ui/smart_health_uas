<div class="card">
  <div class="card-header">
    <h3>Semua Appointment (<%= appointments.length %>)</h3>
  </div>

  <% if (appointments.length === 0) { %>
    <div class="empty-state">
      <div class="empty-state-icon">&#128197;</div>
      <p>Belum ada appointment yang dibuat.</p>
    </div>
  <% } else { %>
    <div class="table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>Pasien</th>
            <th>Dokter</th>
            <th>Jadwal</th>
            <th>Keluhan</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <% appointments.forEach(a => { %>
            <tr>
              <td><%= a.user.username %></td>
              <td><%= a.doctor.user.username %></td>
              <td><%= new Date(a.schedule).toLocaleString('id-ID', { dateStyle: 'medium', timeStyle: 'short' }) %></td>
              <td><%= a.keluhan || '-' %></td>
              <td><span class="badge badge-<%= a.status.toLowerCase() %>"><%= a.status %></span></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>
