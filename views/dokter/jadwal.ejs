<div class="card">
  <div class="card-header">
    <h3>Jadwal Praktik Saya</h3>
    <button class="btn btn-primary btn-sm" onclick="document.getElementById('modalJadwal').style.display='flex'">+ Tambah Jadwal</button>
  </div>

  <% if (doctor.schedules.length === 0) { %>
    <div class="empty-state">
      <div class="empty-state-icon">&#128337;</div>
      <p>Anda belum mengatur jadwal praktik. Tambahkan agar pasien bisa booking.</p>
    </div>
  <% } else { %>
    <div class="table-wrap">
      <table class="data-table">
        <thead>
          <tr><th>Hari</th><th>Jam Mulai</th><th>Jam Selesai</th><th>Aksi</th></tr>
        </thead>
        <tbody>
          <% doctor.schedules.forEach(s => { %>
            <tr>
              <td><strong><%= s.dayOfWeek %></strong></td>
              <td><%= s.startTime %></td>
              <td><%= s.endTime %></td>
              <td><button class="btn btn-danger btn-sm" onclick="hapusJadwal(<%= s.id %>)">Hapus</button></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<div id="modalJadwal" class="modal-overlay">
  <div class="modal-box">
    <h3 style="margin-bottom: 18px;">Tambah Jadwal Praktik</h3>
    <form id="formJadwal">
      <div class="form-group">
        <label class="form-label">Hari</label>
        <select name="dayOfWeek" class="form-select" required>
          <option value="Senin">Senin</option>
          <option value="Selasa">Selasa</option>
          <option value="Rabu">Rabu</option>
          <option value="Kamis">Kamis</option>
          <option value="Jumat">Jumat</option>
          <option value="Sabtu">Sabtu</option>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label">Jam Mulai</label>
        <input type="time" name="startTime" class="form-input" required>
      </div>
      <div class="form-group">
        <label class="form-label">Jam Selesai</label>
        <input type="time" name="endTime" class="form-input" required>
      </div>
      <div style="display:flex; gap: 10px; margin-top: 6px;">
        <button type="button" class="btn btn-outline btn-block" onclick="document.getElementById('modalJadwal').style.display='none'">Batal</button>
        <button type="submit" class="btn btn-primary btn-block">Simpan</button>
      </div>
    </form>
  </div>
</div>

<style>
.modal-overlay { display: none; position: fixed; top:0; left:0; width:100%; height:100%; background: rgba(15,76,76,0.45); align-items: center; justify-content: center; z-index: 100; }
.modal-box { background: white; border-radius: var(--radius-md); padding: 28px; width: 100%; max-width: 420px; }
</style>

<script>
const doctorId = <%= doctor.id %>;

document.getElementById('formJadwal').addEventListener('submit', async (e) => {
  e.preventDefault();
  const data = Object.fromEntries(new FormData(e.target));
  const res = await fetch(`/api/doctors/${doctorId}/schedules`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(data)
  });
  if (res.ok) { location.reload(); } else {
    const r = await res.json(); alert(r.message || 'Gagal menambahkan jadwal.');
  }
});

async function hapusJadwal(id) {
  if (!confirm('Hapus jadwal ini?')) return;
  const res = await fetch(`/api/doctors/schedules/${id}`, { method: 'DELETE' });
  if (res.ok) { location.reload(); } else {
    const r = await res.json(); alert(r.message || 'Gagal menghapus jadwal.');
  }
}
</script>
